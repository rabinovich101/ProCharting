{
  "name": "@procharting/monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Ultra-high-performance financial charting library",
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "bench": "pnpm -r bench",
    "lint": "eslint packages/*/src TEST/binance-chart-test/app --ext .ts,.tsx",
    "typecheck": "pnpm run typecheck:packages && pnpm run typecheck:test",
    "typecheck:packages": "pnpm --filter './packages/*' exec tsc -p tsconfig.json --noEmit --composite false --incremental false --pretty false",
    "typecheck:test": "tsc -p TEST/binance-chart-test/tsconfig.json --noEmit --pretty false",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  },
  "pnpm": {
    "overrides": {}
  }
}
